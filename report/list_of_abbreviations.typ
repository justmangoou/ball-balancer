#table(
  columns: (1fr, 3fr),
  inset: (y: 10pt),
  stroke: none,

  [ADC],  
  [Analog-to-Digital Converter \
  Bộ chuyển đổi tín hiệu tương tự sang tín hiệu số.],

  [ARM],
  [Advanced RISC Machine \
  Kiến trúc vi xử lý dựa trên tập lệnh rút gọn (RISC).],

  [DC],
  [Direct Current \
  Dòng điện một chiều.],

  [DIP],
  [Dual In-line Package (hoặc Dual In-line Pins) \
  Kiểu chân linh kiện có hai hàng chân song song, khoảng cách tiêu chuẩn (thường là 2.54mm).],

  [DWT],
  [Data Watchpoint and Trace \
  Khối ngoại vi thuộc lõi ARM hỗ trợ giám sát hệ thống và cung cấp bộ đếm chu kỳ xung nhịp.],

  [FFC],
  [Flexible Flat Cable \
  Cáp dẹt mềm, dùng để kết nối dẫn điện giữa các bo mạch hoặc module thông qua đầu cắm chuyên dụng.],

  [FPC],
  [Flexible Printed Circuit \
  Mạch in dẻo, có thể tích hợp linh kiện và đường mạch phức tạp trên nền vật liệu đàn hồi, dùng cho các kết nối nhỏ gọn.],

  [FPU],  
  [Floating Point Unit \
  Bộ xử lý số học dấu chấm động.],

  [GPIO], 
  [General Purpose Input/Output \
  Các chân vào/ra đa dụng của vi điều khiển.],

  [IDE],  
  [Integrated Development Environment \
  Môi trường phát triển tích hợp dùng để viết, biên dịch và quản lý mã nguồn.],
 
  [NEMA],
  [National Electrical Manufacturers Association \
  Chuẩn kích thước mặt bích động cơ (ví dụ NEMA 17).],

  [PID],  
  [Proportional–Integral–Derivative \
  Thuật toán điều khiển phản hồi gồm ba thành phần Tỉ lệ (P), Tích phân (I) và Đạo hàm (D).],

  [PWM],  
  [Pulse Width Modulation \
  Kỹ thuật điều chế độ rộng xung dùng để kiểm soát mức cống suất trung bình.],

  [RMS],
  [Root Mean Square \
  Giá trị hiệu dụng của tín hiệu (ví dụ điện áp/dòng), tương đương giá trị DC tạo ra cùng công suất trên tải.],

  [ROM],  
  [Read-Only Memory \
  Bộ nhớ chỉ đọc, dùng để lưu trữ chương trình.],

  [RPS],
  [Revolute–Prismatic–Spherical \
  Chuỗi khớp quay–tịnh tiến–cầu trong cơ cấu robot song song.],

  [SRAM], 
  [Static Random Access Memory \
  Bộ nhớ truy cập ngẫu nhiên tĩnh, dùng để lưu dữ liệu tạm thời khi chạy chương trình.],

  [SYSCLK],
  [System clock \
  Xung nhịp hệ thống của vi điều khiển.],

  [TIM],  
  [Timer \
  Bộ định thời: tạo mốc thời gian và xung nhịp để đếm, tạo ngắt định kỳ, đo độ rộng/tần số xung và tạo PWM.],

  [UART],
  [Universal Asynchronous Receiver/Transmitter \
  Chuẩn truyền nhận dữ liệu nối tiếp bất đồng bộ.]
)